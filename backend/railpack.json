{
  "extensions": [
    "ctype",
    "curl",
    "dom",
    "fileinfo",
    "filter",
    "gd",
    "hash",
    "mbstring",
    "openssl",
    "pcre",
    "pdo",
    "pdo_mysql",
    "session",
    "tokenizer",
    "xml"
  ],
  "start": "php -S 0.0.0.0:$PORT -t public",
  "buildCommand": "composer install --optimize-autoloader --no-scripts --no-interaction && php artisan config:cache && php artisan route:cache && php artisan view:cache",
  "startCommand": "php artisan serve --host=0.0.0.0 --port=${PORT:-8080}",
  "variables": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "CACHE_DRIVER": "file",
    "SESSION_DRIVER": "file"
  }
}